# ══════════════════════════════════════════════════════════════
# Nirikshak AI — Environment Variables Template
# Copy to .env and fill in ALL values before production deploy
# NEVER commit .env to version control
# ══════════════════════════════════════════════════════════════

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_DB=nirikshak
POSTGRES_USER=nirikshak
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# ── Spring Boot ───────────────────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/nirikshak
SPRING_DATASOURCE_USERNAME=nirikshak
SPRING_DATASOURCE_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE

# JWT — MUST be >= 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_48

# ── AI Vision (Python) ────────────────────────────────────────
AI_VISION_SERVICE_URL=http://python-ai:8000
AI_VISION_TIMEOUT_MS=2000

# Gaze/pose thresholds (degrees)
YAW_THRESHOLD=25
PITCH_THRESHOLD=20
GAZE_YAW_THR=20
GAZE_PITCH_THR=15
GAZE_WEIGHT=0.4

# ── React Frontend ────────────────────────────────────────────
REACT_APP_BACKEND_URL=https://yourdomain.com
REACT_APP_WS_URL=wss://yourdomain.com

# ── SSL (Production only) ─────────────────────────────────────
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem
