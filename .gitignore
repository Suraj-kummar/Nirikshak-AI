# Nirikshak AI — .gitignore

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
.env
*.egg-info/
dist/
build/

# ── Java / Maven ──────────────────────────────────────────────────────────────
backend/target/
*.class
*.jar
*.war
*.log
.mvn/

# ── Node / React ──────────────────────────────────────────────────────────────
frontend/node_modules/
frontend/build/
.npm/
yarn.lock

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── IDEs ──────────────────────────────────────────────────────────────────────
.idea/
*.iml
.vscode/settings.json
.vscode/launch.json

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Secrets ───────────────────────────────────────────────────────────────────
.env
.env.local
.env.production
*.pem
*.key

# ── PostgreSQL data ────────────────────────────────────────────────────────────
pgdata/
